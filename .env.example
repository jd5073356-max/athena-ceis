# Athena — ejemplo de variables de entorno.
# Copia este archivo a ".env" y rellena los valores. NUNCA subas .env al repo.
# En desarrollo puedes dejarlo casi vacío: los valores por defecto usan SQLite
# y almacenamiento local, y todo corre tal cual.

# === General / seguridad ===================================================
# Genera una con: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=dev-inseguro-cambiar-en-produccion
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://tu-dominio.com

# === Base de datos =========================================================
# sqlite (desarrollo) | oracle (producción)
DB_ENGINE=sqlite
# --- Solo si DB_ENGINE=oracle ---
# ORACLE_DSN=athena_high            # alias TNS del wallet (ver tnsnames.ora)
# ORACLE_USER=ADMIN
# ORACLE_PASSWORD=...               # contraseña del usuario ADMIN de la ADB
# TNS_ADMIN=/home/juan/oracle/athena-wallet   # carpeta del wallet descomprimido
# ORACLE_WALLET_PASSWORD=...        # contraseña que pusiste al DESCARGAR el wallet

# === Almacenamiento de archivos ============================================
# local (desarrollo, media/) | oci (producción, Object Storage)
STORAGE_BACKEND=local
# --- Solo si STORAGE_BACKEND=oci ---
# OCI_NAMESPACE=...
# OCI_BUCKET=athena-archivos
# OCI_REGION=sa-bogota-1
# OCI_AUTH=config                   # config | instance_principal
# OCI_CONFIG_FILE=~/.oci/config
# OCI_CONFIG_PROFILE=DEFAULT
# OCI_PUBLIC=false
# OCI_PAR_BASE_URL=                 # URL de un Pre-Authenticated Request (bucket privado)
